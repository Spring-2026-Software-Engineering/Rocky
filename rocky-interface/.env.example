# Frontend public environment variables.
# These are exposed to the browser and must not contain secrets.

# development | testing | production
PUBLIC_APP_ENV=development

# Backend base URL consumed by frontend API clients.
PUBLIC_API_BASE_URL=http://127.0.0.1:5001

# Enables the DBtest route in non-production environments.
PUBLIC_ENABLE_DBTEST=true

# Enable Microsoft OAuth only in development when explicitly set to true.
# Production always uses Microsoft OAuth. Testing always uses preview auth.
PUBLIC_ENABLE_MICROSOFT_OAUTH=false

# Microsoft Entra app registration client ID (required when Microsoft OAuth is active).
PUBLIC_MICROSOFT_CLIENT_ID=

# Tenant ID or common/organizations.
PUBLIC_MICROSOFT_TENANT_ID=common

# Frontend bind host used by dev and preview launchers.
ROCKY_WEB_HOST=127.0.0.1

# Frontend bind port used by dev and preview launchers.
ROCKY_WEB_PORT=5000

# Comma-separated hostnames allowed by Vite during development.
ROCKY_ALLOWED_HOSTS=localhost,127.0.0.1
