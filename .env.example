# Root convenience variables used by helper scripts.
# This file is optional and can override service-level .env values.

# development | testing | production
ROCKY_APP_ENV=development

# Backend API bind settings.
ROCKY_API_HOST=127.0.0.1
ROCKY_API_PORT=5001

# Frontend bind settings used by dev and preview launchers.
ROCKY_WEB_HOST=127.0.0.1
ROCKY_WEB_PORT=5000

# Comma-separated hostnames allowed by Vite during development.
ROCKY_ALLOWED_HOSTS=localhost,127.0.0.1
