# Backend runtime environment configuration.

# development | testing | production
ROCKY_APP_ENV=development

# Backend API bind host and port.
ROCKY_API_HOST=127.0.0.1
ROCKY_API_PORT=5001

# Enable debug mode locally only.
ROCKY_DEBUG=true

# Set to mongodb for production deployments.
# Use mongita only for local development/testing fallback.
ROCKY_DB_BACKEND=mongita

# Required when ROCKY_APP_ENV=production.
# Example format: mongodb+srv://user:password@cluster/db?retryWrites=true&w=majority
ROCKY_MONGODB_URI=

# Database name for MongoDB or Mongita.
ROCKY_DB_NAME=rocky_db

# Disable in production to avoid exposing data inspector.
ROCKY_ENABLE_DB_INSPECTOR=true

# Enable Microsoft OAuth in development when set to true.
# Production always enables Microsoft OAuth.
# Testing always disables Microsoft OAuth.
ROCKY_ENABLE_MICROSOFT_OAUTH=false
