ROCKY_APP_ENV=development
ROCKY_API_HOST=127.0.0.1
ROCKY_API_PORT=5001
ROCKY_DEBUG=true

# Set to mongodb for production deployments. Keep mongita for local development fallback.
ROCKY_DB_BACKEND=mongita
ROCKY_MONGODB_URI=
ROCKY_DB_NAME=rocky_db

# Disable in production.
ROCKY_ENABLE_DB_INSPECTOR=true
ROCKY_ENABLE_PREVIEW_LOGIN=true
